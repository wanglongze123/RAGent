# 复制此文件为 .env，填入真实值，.env 已在 .gitignore 中，不会被提交

# ===== 豆包 API =====
DOUBAO_API_KEY=your_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
DOUBAO_MODEL=ep-20260514111645-lmgt2
DOUBAO_EMBEDDING_MODEL=doubao-embedding-vision

# ===== 运行环境 =====
# development（本地）或 production（火山云）
ENVIRONMENT=development

# ===== 存储配置 =====
# 本地用 chroma，生产用 vikingdb
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# 本地用 sqlite，生产用 mysql
DB_TYPE=sqlite
SQLITE_DB_PATH=./app.db

# ===== 生产环境专用（本地留空）=====
REDIS_URL=
VIKINGDB_HOST=
VIKINGDB_REGION=
VIKINGDB_AK=
VIKINGDB_SK=
MYSQL_URL=

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
